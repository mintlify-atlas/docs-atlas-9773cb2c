  "keyFeatures": [
    "Automated RBI compliance monitoring and updates",
    "AI-powered audit report generation with minimal human intervention",
    "Multi-account type support (Savings, Current, Salary, Fixed Deposit, Recurring Deposit, NRI)",
    "KYC and AML compliance checking with suspicious activity detection",
    "Secure vector store architecture for privacy and data security",
    "Real-time compliance insights and analytics dashboard",
    "Azure OpenAI integration for intelligent document analysis",
    "Scalable cloud-native architecture"
  ],
  "publicApiSurface": [
    "GET /AML_guidelines/ - Retrieve AML compliance guidelines",
    "POST /AML_guidelines/ - Update AML compliance guidelines",
    "GET /KYC_guidelines/ - Retrieve KYC compliance guidelines",
    "POST /KYC_guidelines/ - Update KYC compliance guidelines",
    "GET /bank_accounts/ - List all bank accounts",
    "POST /bank_accounts/ - Create a new bank account",
    "GET /bank_accounts/<adhaar_number>/<account_type>/ - Get specific account details",
    "PUT /bank_accounts/<adhaar_number>/<account_type>/ - Update account details",
    "DELETE /bank_accounts/<adhaar_number>/<account_type>/ - Delete account",
    "complianceAssitant.main() - Generate compliance audit reports",
    "userBankAccountInsightsGenerator.main() - Generate account insights",
    "RBI_DataFetcher - Fetch and process RBI guidelines"
  ]
